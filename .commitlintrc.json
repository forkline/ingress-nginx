{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "Build",
        "build",
        "Chore",
        "chore",
        "CI",
        "ci",
        "Docs",
        "docs",
        "Feat",
        "feat",
        "Fix",
        "fix",
        "Merge",
        "merge",
        "Perf",
        "perf",
        "Refactor",
        "refactor",
        "Release",
        "release",
        "Revert",
        "revert",
        "Style",
        "style",
        "Test",
        "test"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "admission",
        "api",
        "chart",
        "ci",
        "commitlint",
        "config",
        "controller",
        "coverage",
        "deps",
        "docs",
        "e2e",
        "helm",
        "image",
        "lua",
        "nginx",
        "pre-commit",
        "release",
        "security",
        "template",
        "test",
        "tests",
        "webhook"
      ]
    ],
    "subject-case": [
      0
    ],
    "body-leading-blank": [
      2,
      "always"
    ],
    "footer-leading-blank": [
      1,
      "always"
    ]
  }
}
